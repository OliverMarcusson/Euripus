<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".EuripusReceiverApplication"
        android:allowBackup="true"
        android:banner="@drawable/euripus_atv_banner"
        android:icon="@drawable/euripus_icon"
        android:label="@string/app_name"
        android:logo="@drawable/euripus_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.EuripusReceiver">
        <activity
            android:name=".MainActivity"
            android:banner="@drawable/euripus_atv_banner"
            android:icon="@drawable/euripus_icon"
            android:logo="@drawable/euripus_icon"
            android:configChanges="keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
