{
  "name": "euripus",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:start": "bun ./scripts/run-script.mjs dev:start",
    "dev:stop": "bun ./scripts/run-script.mjs dev:stop",
    "dev:reset": "bun ./scripts/run-script.mjs dev:reset",
    "prod:start": "bun ./scripts/run-script.mjs prod:start",
    "prod:stop": "bun ./scripts/run-script.mjs prod:stop",
    "prod:reset": "bun ./scripts/run-script.mjs prod:reset",
    "publish": "bun ./scripts/run-script.mjs publish",
    "deploy": "bun ./scripts/run-script.mjs deploy",
    "build:shared": "bun --cwd packages/shared build",
    "build:client": "bun --cwd apps/client build",
    "build:apk": "bun ./scripts/run-script.mjs build:apk",
    "check:client": "bun --cwd apps/client typecheck",
    "test:client": "bun --cwd apps/client test",
    "test:server": "cargo test --manifest-path apps/server/Cargo.toml"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
