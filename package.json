{
  "name": "euripus",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:desktop": "bun --cwd apps/desktop dev",
    "dev:server": "docker compose up --build server",
    "dev:db": "docker compose up -d postgres",
    "user-test:start": "bun ./scripts/run-dev-script.mjs user-test:start",
    "user-test:start:web": "bun ./scripts/run-dev-script.mjs user-test:start:web",
    "user-test:start:dev": "bun ./scripts/run-dev-script.mjs user-test:start:dev",
    "user-test:start:dev:web": "bun ./scripts/run-dev-script.mjs user-test:start:dev:web",
    "user-test:stop": "bun ./scripts/run-dev-script.mjs user-test:stop",
    "homelab:publish": "powershell -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File ./scripts/publish-homelab-images.ps1",
    "build:shared": "bun --cwd packages/shared build",
    "build:desktop": "bun --cwd apps/desktop build",
    "build:android-tv": "powershell -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File ./scripts/build-android-tv.ps1",
    "check:desktop": "bun --cwd apps/desktop typecheck",
    "test:desktop": "bun --cwd apps/desktop test",
    "test:server": "cargo test --manifest-path apps/server/Cargo.toml",
    "tauri:dev": "bun --cwd apps/desktop tauri dev",
    "tauri:build": "bun --cwd apps/desktop tauri build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
